{
  "Document": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "AWSPartnerCentralSandboxAccess",
        "Effect": "Allow",
        "Action": [
          "partnercentral:*"
        ],
        "Resource": "*",
        "Condition": {
          "StringEquals": {
            "partnercentral:Catalog": "Sandbox"
          }
        }
      },
      {
        "Sid": "PassAWSPartnerCentralSnapshotJobRole",
        "Effect": "Allow",
        "Action": [
          "iam:PassRole"
        ],
        "Resource": [
          "arn:aws:iam::*:role/*"
        ],
        "Condition": {
          "StringEquals": {
            "iam:PassedToService": "resource-snapshot-job.partnercentral-selling.amazonaws.com"
          }
        }
      }
    ]
  },
  "VersionId": "v4",
  "IsDefaultVersion": true,
  "CreateDate": "2026-02-12T17:59:18+00:00"
}
